[ T i t l e ]
input file for lecture about tally

[ P a r a m e t e r s ]
 icntl    =           0     # (D=0) 3:ECH 5:NOR 6:SRC 7,8:GSH 11:DSH 12:DUMP
 maxcas   =          1000000     # (D=10) number of particles per one batch
 maxbch   =           10     # (D=10) number of batches

[ S o u r c e ]
   s-type =   1             # mono-energetic axial source
       z0 =  0.           # minimum position of z-axis [cm]
       z1 =  0.           # maximum position of z-axis [cm]
       r0 =   0.5           # radius [cm]
      dir =   1.0           # z-direction of beam [cosine]
       e0 =   80.          # energy of beam [MeV/u]
     proj =  proton            # kind of incident nucleus
trcl = 1

[ M a t e r i a l ]
mat[1]    H 2  O 1

[Transform]
*tr1   0     20     0     0  0  45    0  0   0  0   0  0    2 

[ Mat Name Color ]
    mat   name      color
     1    Water     pastelblue

[ S u r f a c e ]
  10  c/x      0 20 5.
 101  px       -5.
 102  px      5.
 999  so     500.

[ C e l l ]
  1     1 -1.0  -10  101  -102
 100    0      -999  #all
 101   -1       999

[ T - Deposit ]
    mesh = r-z
  r-type = 1
      nr = 1
    0.0  1.0
  z-type = 2
    nz = 200
    zmin = 0.
    zmax =  40.
     unit =    1            # unit is [MeV/cm^3/source]
 material =  all            # (D=all) number of specific material
   output =  dose           # total deposit energy
     axis =    z           # axis of output
     file = deposit.out     # file name of output for the above axis
     part =  all      
    gshow =    3            # 0: no 1:bnd, 2:bnd+mat, 3:bnd+reg 4:bnd+lat
   epsout =    1            # (D=0) generate eps file by ANGEL
      $trcl=1

[ T - T r a c k ] off $1
    title = Track Detection in xyz mesh
     mesh =  xyz            # mesh type is xyz scoring mesh
   x-type =    2            # x-mesh is linear given by xmin, xmax and nx
       nx =   100            # number of x-mesh points
     xmin =  -25.           # minimum value of x-mesh points
     xmax =   25.           # maximum value of x-mesh points
   y-type =    1            # y-mesh is given by the below data
       ny =    1            # number of y-mesh points
           -5.0  5.0
   z-type =    2            # z-mesh is linear given by zmin, zmax and nz
       nz =   100            # number of z-mesh points
     zmin =  -20.           # minimum value of z-mesh points
     zmax =   60.           # maximum value of z-mesh points
   e-type =    1            # e-mesh is given by the below data
       ne =    1            # number of e-mesh points
            0.0  5000.0
     unit =    1            # unit is [1/cm^2/source]
     axis =   xz            # axis of output
     file = track_xz.out  # file name of output for the above axis
     part =  all      
    gshow =    3            # 0: no 1:bnd, 2:bnd+mat, 3:bnd+reg 4:bnd+lat
   epsout =    1            # (D=0) generate eps file by ANGEL

[ T - T r a c k ] $2
    title = Track Detection in xyz mesh
     mesh =  xyz            # mesh type is xyz scoring mesh
   x-type =    1            # y-mesh is given by the below data
       nx =    1            # number of y-mesh points
           -5.0  5.0
   y-type =    2            # x-mesh is linear given by xmin, xmax and nx
       ny =   300            # number of x-mesh points
     ymin =  -20.           # minimum value of x-mesh points
     ymax =   20.           # maximum value of x-mesh points
   z-type =    2            # z-mesh is linear given by zmin, zmax and nz
       nz =   300            # number of z-mesh points
     zmin =  0.           # minimum value of z-mesh points
     zmax =   40.           # maximum value of z-mesh points
   e-type =    1            # e-mesh is given by the below data
       ne =    1            # number of e-mesh points
            0.0  5000.0
     unit =    1            # unit is [1/cm^2/source]
     axis =   yz            # axis of output
     file = track_yz.out  # file name of output for the above axis
     part =  all      
    gshow =    3            # 0: no 1:bnd, 2:bnd+mat, 3:bnd+reg 4:bnd+lat
   epsout =    1            # (D=0) generate eps file by ANGEL

   
[ T - T r a c k ] off $3
    title = Track Detection in xyz mesh
     mesh =  xyz            # mesh type is xyz scoring mesh
	   x-type =    2            # z-mesh is linear given by zmin, zmax and nz
       nx =   100            # number of z-mesh points
     xmin =  -25.           # minimum value of z-mesh points
     xmax =   25.           # maximum value of z-mesh points
   y-type =    2            # x-mesh is linear given by xmin, xmax and nx
       ny =   100            # number of x-mesh points
     ymin =  -25.           # minimum value of x-mesh points
     ymax =   25.           # maximum value of x-mesh points

	    z-type =    1            # y-mesh is given by the below data
       nz =    1            # number of y-mesh points
           -5.0  5.0
   e-type =    1            # e-mesh is given by the below data
       ne =    1            # number of e-mesh points
            0.0  5000.0
   t-type =    1            # t-mesh is given by the below data
       nt =    1            # number of t-mesh points
            0.0  1.0e+6
     unit =    1            # unit is [1/cm^2/source]
     axis =   xy            # axis of output
     file = track_xy.out  # file name of output for the above axis
     part =  all      
    gshow =    3            # 0: no 1:bnd, 2:bnd+mat, 3:bnd+reg 4:bnd+lat
   epsout =    1            # (D=0) generate eps file by ANGEL

[ E n d ]
